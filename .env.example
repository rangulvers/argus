# Argus secrets — copy to .env, fill in your values, never commit .env to git!

# Session signing key (REQUIRED in production)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ARGUS_SESSION_SECRET=replace-with-a-random-32-char-string

# CVE database (get free key at nvd.nist.gov)
ARGUS_CVE_API_KEY=

# UniFi integration
ARGUS_UNIFI_PASSWORD=
ARGUS_UNIFI_API_KEY=

# Pi-hole
ARGUS_PIHOLE_API_TOKEN=

# AdGuard
ARGUS_ADGUARD_PASSWORD=
